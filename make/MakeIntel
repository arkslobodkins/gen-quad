assertions = 1
OPENMP     = 1
debug      = 1

CXX = icpc
CC  = icc
CXXFLAGS = -g -Wall -O3 -xhost -I../plasma-17.1/include #qopt-report
CFLAGS   = -g -Wall -O3 -xhost -I../plasma-17.1/include #qopt-report

CVERSION   = -std=c11
CPPVERSION = -std=c++11

ifeq ($(OPENMP), 1)
CFLAGS   += -qopenmp
CXXFLAGS += -qopenmp
endif

ifeq ($(assertions), 0)
CFLAGS   += -DNDEBUG
CXXFLAGS += -DNDEBUG
endif

ifeq ($(debug), 0)
CFLAGS   += -DQUAD_DEBUG_OFF
CXXFLAGS += -DQUAD_DEBUG_OFF
endif

LIBSBLAS= -mkl
MATH= -lm
RANLIB = ranlib
VPATH= ../src:../src/Gauss_Lib


OBJECTS = Main.o LeastSquaresNewton.o  GeneralGaussTensor.o GENERAL_QUADRATURE.o GetJacobian.o  \
	GetFunction.o NodeElimination.o Output.o AddDimension.o ComputeDomain.o QuadDriver.o         \
	Constraints.o ConstrainedOptimization.o Vector.o Matrix.o Tensor.o Print.o Quadrature.o      \
	LINALG.o Basis.o get_time.o libgaussq.a libplasma_icc.a libcoreblas_icc.a

all:quadc quadcpp

quadc : quad_c results
quad_c : $(OBJECTS)
	$(CC) $(CVERSION) $(CFLAGS) -o $@ $^ $(LIBSBLAS) $(MATH)

quadcpp : quad_cpp results
quad_cpp : $(OBJECTS)
	$(CXX) $(CPPVERSION) $(CXXFLAGS) -o $@ $^ $(LIBSBLAS) $(MATH)


OBJS = GaussCore.o Jacobi.o
libgaussq.a : $(OBJS)
	$(AR) rv libgaussq.a $(OBJS)
	$(RANLIB) libgaussq.a

results:
	mkdir -p ../results

clean:
	\rm -f *.o quad_c quad_cpp

distclean : clean txtclean
	\rm -f quad_c quad_cpp *~

SUBDIR_ROOTS := ../results
DIRS := . $(shell find $(SUBDIR_ROOTS) -type d)
PATTERNS := *.txt *.png
TXT_FILES := $(foreach DIR,$(DIRS),$(addprefix $(DIR)/,$(PATTERNS)))
txtclean:
	rm -rf $(TXT_FILES)

