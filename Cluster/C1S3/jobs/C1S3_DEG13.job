#!/bin/bash
#SBATCH -J C1S3_DEG13
#SBATCH -o C1S3_DEG13.txt
#SBATCH -e C1S3_DEG13.err
#SBATCH -p standard-mem-s
#SBATCH --exclusive
#SBATCH --mem=8G
#SBATCH --nodes=1
#SBATCH --chdir ../output

cd ../../../make

module purge
module load gcc-9.2
module load openblas/0.3.7-ai63y24
export OMP_NUM_THREADS=36

make clean
make quadc
./quad_c CUBESIMPLEX 13 1 3
make clean
