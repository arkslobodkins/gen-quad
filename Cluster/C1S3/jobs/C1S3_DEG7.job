#!/bin/bash
#SBATCH -J C1S3_DEG7
#SBATCH -o C1S3_DEG7.txt
#SBATCH -e C1S3_DEG7.err
#SBATCH -p development
#SBATCH -t 2
#SBATCH --mem=1G
#SBATCH --nodes=1
#SBATCH --chdir ../output

cd ../../../make

module purge
module load gcc-9.2
module load openblas/0.3.7-ai63y24
export OMP_NUM_THREADS=28

make clean
make quadc
./quad_c CUBESIMPLEX 7 1 3
make clean
