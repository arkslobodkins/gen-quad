#!/bin/bash
#SBATCH -J S2S2_DEG9
#SBATCH -o S2S2_DEG9.txt
#SBATCH -e S2S2_DEG9.err
#SBATCH -p development
#SBATCH -t 30
#SBATCH --mem=1G
#SBATCH --nodes=1
#SBATCH --chdir ../output

cd ../../../make

module purge
module load gcc-9.2
module load openblas/0.3.7-ai63y24
export OMP_NUM_THREADS=36

make clean
make quadc
./quad_c SIMPLEXSIMPLEX 9 2 2
make clean
