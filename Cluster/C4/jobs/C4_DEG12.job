#!/bin/bash
#SBATCH -J C4_DEG12
#SBATCH -o C4_DEG12.txt
#SBATCH -e C4_DEG12.err
#SBATCH -p standard-mem-s
#SBATCH -t 400
#SBATCH --exclusive
#SBATCH --mem=4G
#SBATCH --nodes=1
#SBATCH --chdir ../output

cd ../../../make

module purge
module load gcc-9.2
module load openblas/0.3.7-ai63y24
export OMP_NUM_THREADS=36

make clean
make quadc
./quad_c CUBE 12 4
make clean
